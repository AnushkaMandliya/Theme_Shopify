{{ 'Custom-About-Us.css' | asset_url | stylesheet_tag }}


<div class="video-text-wrapper">

    <h2 class="About-us-heading">Why Aura ? </h2>

   <div class="about-us-main-wrapper
    {% if section.settings.video_right %}
     video-right
    {% else %}
      video-left  
    {% endif %}
    ">

      <div class="video-box video-box--{{ section.settings.video_width }}">
    
        {% if section.settings.video != blank %}
          {{
            section.settings.video
            | video_tag:
              autoplay: true,
              loop: true,
              muted: true,
              controls: false,
              class: 'about-video'
          }}
        {% endif %}

      </div>

      <div class="text-box" style="text-align: {{ section.settings.Text_Align }};">

        <h2 style="font-size: {{ section.settings.Heading_Font_Size }}px;">
          {{ section.settings.heading }}
        </h2>

        <p style="font-size: {{ section.settings.Paragraph_Font_Size }}px;">
          {{ section.settings.text }}
        </p>

        <div class="ending-line">

        </div>

      </div>
   </div>


</div>


{% schema %}
  {
    "name": "Custom-About-Us",
    "class": "section",
    "settings": [
      {
        "type": "video",
        "id": "video",
        "label": "Select Video"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Image with text"
      },
      {
        "type": "textarea",
        "id": "text",
        "label": "Description",
        "default": "This is image on left and text on right section"
      },
      {
        "type": "select",
        "id": "video_width",
        "options": [
          { "value": "small", "label": "Small" },
          { "value": "medium", "label": "Medium" },
          { "value": "large", "label": "Large" }
        ],
        "default": "medium",
        "label": "Video Width"
      },
      {
        "type": "range",
        "id": "Heading_Font_Size",
        "min": 35,
        "max": 70,
        "default": 40,
        "label": "Heading_Font_Size"
      },
      {
        "type": "range",
        "id": "Paragraph_Font_Size",
        "min": 15,
        "max": 40,
        "default": 18,
        "label": "Paragraph_Font_Size"
      },
      {
        "type": "select",
        "id": "Text_Align",
        "options": [
          { "value": "left", "label": "Left" },
          { "value": "center", "label": "Center" },
          { "value": "right", "label": "Right" }
        ],
        "default": "center",
        "label": "Text_Align"
      },
      {
        "type": "checkbox",
        "id": "video_right",
        "default": false,
        "label": "Enable Direction Changing"
      }
      
    ],

    "presets": [
      {
        "name": "Custom-About-Us"
      }
    ]
  }
{% endschema %}
