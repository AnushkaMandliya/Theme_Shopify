{{ 'custom-best-sellers.css' | asset_url | stylesheet_tag }}

<section class="custom-best-sellers-wrapper page-width">

  <div class="best-seller-header">

    {% comment %} Left arrow {% endcomment %}
    <svg width="30px" height="30px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="best-prev">
      <g id="SVGRepo_bgCarrier" stroke-width="0"></g>
      <g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g>
      <g id="SVGRepo_iconCarrier"> 
        <path fill-rule="evenodd" clip-rule="evenodd" d="M11.7071 4.29289C12.0976 4.68342 12.0976 5.31658 11.7071 5.70711L6.41421 11H20C20.5523 11 21 11.4477 21 12C21 12.5523 20.5523 13 20 13H6.41421L11.7071 18.2929C12.0976 18.6834 12.0976 19.3166 11.7071 19.7071C11.3166 20.0976 10.6834 20.0976 10.2929 19.7071L3.29289 12.7071C3.10536 12.5196 3 12.2652 3 12C3 11.7348 3.10536 11.4804 3.29289 11.2929L10.2929 4.29289C10.6834 3.90237 11.3166 3.90237 11.7071 4.29289Z" fill="#000000">
        </path> 
      </g>
    </svg>

    {% comment %} heading {% endcomment %}

    <h2 class="sellers-heading">{{ section.settings.heading }}</h2>

    {% comment %} Right Icon {% endcomment %}

    <svg width="30px" height="30px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="best-next">
      <g id="SVGRepo_bgCarrier" stroke-width="0"></g>
      <g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g>
      <g id="SVGRepo_iconCarrier"> 
        <path fill-rule="evenodd" clip-rule="evenodd" d="M12.2929 4.29289C12.6834 3.90237 13.3166 3.90237 13.7071 4.29289L20.7071 11.2929C21.0976 11.6834 21.0976 12.3166 20.7071 12.7071L13.7071 19.7071C13.3166 20.0976 12.6834 20.0976 12.2929 19.7071C11.9024 19.3166 11.9024 18.6834 12.2929 18.2929L17.5858 13H4C3.44772 13 3 12.5523 3 12C3 11.4477 3.44772 11 4 11H17.5858L12.2929 5.70711C11.9024 5.31658 11.9024 4.68342 12.2929 4.29289Z" fill="#000000">
        </path> 
      </g>
    </svg>

  </div>

  <div class="swiper best-seller-swiper">

    <div class="swiper-wrapper">

      {% assign collection = collections[section.settings.collection] %}

      {% for product in collection.products %}

        <!-- decimal starts -->

          {% assign DEBUG = false %} 
          {% assign decimal = false %} 
          {% assign step = 1 %}
          {% assign minimum_qty = 1 %}
          {% assign product = product | default: card_product %}

          {% assign disp_price_min = product.price_min %}
          {% assign disp_price_compare = product.compare_at_price %}
          {% assign disp_price = product.price %}

          {% if settings.pr_enable_decimal %}

            {% assign pri_unit = settings.pr_unit %}

              {% if settings.pr_common_decimal %}
              
              {% if product.tags contains 'decimal' %}

                {% assign decimal = true %}  
                  {% assign step = settings.pr_decimal_step_size %}
                      {% assign minimum_qty = settings.pr_minimum_qty %}

              {% endif%}

              {% elsif product.metafields.propero['decimal_step_size'] != blank %}  
              
              {% assign step = product.metafields.propero['decimal_step_size'] %}
              {% assign decimal = true %}

              {% endif %}

            {% assign checkout_text = settings.pr_checkout_text |replace :"%UNIT%", pri_unit %}

            {% assign qty_multiple = 1 | divided_by : step %}

            {% assign checkout_text = checkout_text | replace :"%QUANTITY%", qty_multiple   %}	

          {% endif %}

          {% unless settings.pr_common_decimal %}

              {% if product.metafields.propero['minimum_qty'] != blank %}

                  {% assign minimum_qty = product.metafields.propero['minimum_qty'] %}	

              {% endif %}

          {% endunless %}

          {% if template.name == 'product' or template.name == 'collection' or template.name == 'search' or template.name == 'index' %}

              {% assign disp_price = product.price | divided_by : step %}
              {% assign disp_price_min = product.price_min | divided_by : step %}
              {% assign disp_price_compare = product.compare_at_price | divided_by : step %}

          {% endif %}

        <!-- decimal ends -->
        
        <div class="swiper-slide">

          <div class="images">
                <a href="{{ product.url }}" class="image-link">
                    <img src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.title }}"
                        width="{{ product.featured_image.width }}"
                        height="{{ product.featured_image.height }}">
                </a>
          </div>

          <h2>{{ product.title }}</h2>

          {% render 'price', product: product, use_variant: true %}

        </div>
      {% endfor %}

    </div>
  </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", () => {
    new Swiper(".best-seller-swiper", {
        loop: true,
        spaceBetween: 20,
        speed: 600,
        autoplay: {
          delay: 3500,
          disableOnInteraction: false,
        },
        navigation: {
          nextEl: ".best-next",
          prevEl: ".best-prev",
        },
        breakpoints: {
        0: { slidesPerView: 3 },
        768: { slidesPerView: 4, spaceBetween: 30, },
        1024: { slidesPerView: 5 },
        }
    });
    });
</script>



{% schema %}
    {
        "name": "Custom Best Sellers",
        "class": "section",
        "settings": [
            {
                "type": "text",
                "id": "heading",
                "label": "Heading",
                "default": "Best Sellers"
            },
            {
                "type": "collection",
                "id": "collection",
                "label": "Select Collection"
            }
    ],
    "presets": [
        {
        "name": "Custom Best Sellers"
        }
    ]
    }
{% endschema %}
