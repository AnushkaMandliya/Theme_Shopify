{{ 'custom-image-banner.css' | asset_url | stylesheet_tag }}

<div class="image-banner-wrapper swiper banner-swiper" 
     style= "
        --desktop-height: {{ section.settings.desktop_height }};
        --mobile-height: {{ section.settings.mobile_height }};
     "
>
    <div class="swiper-wrapper">

        {% for block in section.blocks %}

            {% if block.type == "slide" %}

                <div class="banner-slide swiper-slide"> 

                    {% if block.settings.banner_image!= blank %} 
                        <img
                            src="{{ block.settings.banner_image | image_url: width: 2000 }}"
                            alt="{{ block.settings.heading | escape }}"
                            width="{{ block.settings.banner_image.width }}"
                            height="{{ block.settings.banner_image.height }}"
                            class="banner-img desktop-img"
                        >
                    {% endif %}


                     <div class="banner-content 
                        desktop-{{ section.settings.desktop_text_position }} 
                        mobile-{{ section.settings.mobile_text_position }}"
                    >
                        {% if block.settings.heading != blank %}
                         <h1>{{ block.settings.heading }}</h1>
                        {% endif %}

                        {% if block.settings.sub_heading != blank %}
                         <p>{{ block.settings.sub_heading }}</p>
                        {% endif %}

                        {% if block.settings.button_text != blank %}
                        <a href="{{ block.settings.button_link }}" class="banner-btn">
                            {{ block.settings.button_text }}
                        </a>
                        {% endif %}
                    </div>
                </div>
                        
            {% endif %}
        {% endfor %}

    </div>

</div>

<script>
  let bannerSwiper;

  function initBannerSwiper() {

    if (bannerSwiper) {
      bannerSwiper.destroy(true, true);
    }

    bannerSwiper = new Swiper(".banner-swiper", {

      loop: true,
      spaceBetween: 30,
      effect: "fade",
      fadeEffect: {
        crossFade: true
      },
      speed: 1200,
      grabCursor: true,


      {% if section.settings.Autoplay_enable %}
      autoplay: {
        delay: {{ section.settings.autoplay_range }},
        disableOnInteraction: false
      }
      {% endif %}
    });
  }

  document.addEventListener("DOMContentLoaded", initBannerSwiper);
  document.addEventListener("shopify:section:load", initBannerSwiper);
</script>

{% schema %}
    {
        "name": "Custom Image Banner",
        "class": "section",
        "settings": [

            {
                "type": "checkbox",
                "id": "Autoplay_enable",
                "label": "AutoPlay Enable",
                "default": false
            },
            {
                "type": "range",
                "id": "autoplay_range",
                "label": "Autoplay Delay in milliseconds ",
                "min": 1000,
                "max": 9000,
                "step": 500,
                "default": 3000

                
            },

            {
                "type": "header",
                "content": "Desktop"
            },
            {
                "type": "select",
                "id": "desktop_text_position",
                "label": "Desktop Text Position",
                "default": "center",
                "options": [
                    { "value": "top", "label": "Top" },
                    { "value": "center", "label": "Center" },
                    { "value": "bottom", "label": "Bottom" },
                    { "value": "left", "label": "Left" },
                    { "value": "right", "label": "Right" }

                ]
            },
            {
                "type": "select",
                "id": "desktop_height",
                "label": "Desktop Height",
                "options": [
                    {
                        "value": "300px",
                        "label": "300px"
                    },
                    {
                        "value": "350px",
                        "label": "350px"
                    },
                    {
                        "value": "400px",
                        "label": "400px"
                    },
                    {
                        "value": "450px",
                        "label": "450px"
                    },
                    {
                        "value": "500px",
                        "label": "500px"
                    },
                    {
                        "value": "550px",
                        "label": "550px"
                    },
                    {
                        "value": "600px",
                        "label": "600px"
                    },
                    {
                        "value": "650px",
                        "label": "650px"
                    },
                    {
                        "value": "700px",
                        "label": "700px"
                    }
                ],
                "default": "500px"
            },


            {
                "type": "header",
                "content": "Mobile"
            },
            {
                "type": "select",
                "id": "mobile_text_position",
                "label": "Mobile Text Position",
                "default": "center",
                "options": [
                    { "value": "top", "label": "Top" },
                    { "value": "center", "label": "Center" },
                    { "value": "bottom", "label": "Bottom" }
                ]
            },
            {
                "type": "select",
                "id": "mobile_height",
                "label": "Mobile Height",
                "options": [
                    {
                        "value": "200px",
                        "label": "200px"
                    },
                    {
                        "value": "250px",
                        "label": "250px"
                    },
                    {
                        "value": "300px",
                        "label": "300px"
                    },
                    {
                        "value": "350px",
                        "label": "350px"
                    },
                    {
                        "value": "400px",
                        "label": "400px"
                    }
                ],
                "default": "300px"
            },

        ],

        "blocks": [
            {
                "type": "slide",
                "name": "Banner Slide",
                "settings": [

                    {
                        "type": "header",
                        "content": "Text Content"
                    },
                    {
                        "type": "text",
                        "id": "heading",
                        "label": "Heading",
                        "default": "Slide Heading"
                    },
                    {
                        "type": "text",
                        "id": "sub_heading",
                        "label": "Sub Heading",
                        "default": "Slide sub heading"
                    },
                    {
                        "type": "text",
                        "id": "button_text",
                        "label": "Button Text",
                        "default": "Shop Now"
                    },
                    {
                        "type": "url",
                        "id": "button_link",
                        "label": "Button Link"
                    },

                    {
                        "type": "image_picker",
                        "id": "banner_image",
                        "label": "Banner Image"
                    },
                ]
            }

        ],

        "presets": [
            {
            "name": "Custom Image Banner"
            }
        ]
    }
{% endschema %}
