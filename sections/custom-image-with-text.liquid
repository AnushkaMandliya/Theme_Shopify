{{ 'custom-image-with-text.css' | asset_url | stylesheet_tag }}


<div class="img-text-wrapper 
  {% if section.settings.image_right %}
     image-right
  {% else %}
   image-left  
  {% endif %}
">

  <div class="img-box img-box--{{ section.settings.main_image_width }}">
    
    {% if section.settings.mainImage != blank %}
      <img 
        src="{{ section.settings.mainImage | image_url: width: 800 }}"
        alt="{{ section.settings.heading | escape }}"
        class="desktop-img"
        width="{{ section.settings.mainImage.width }}"
        height="{{ section.settings.mainImage.height }}"
      >
    {% endif %}

  </div>

  <div class="text-box" style="text-align: {{ section.settings.Text_Align }};">

    <h3 style="font-size: {{ section.settings.Sub_Heading_Font_Size }}px;" class="sub-heading">
      {{ section.settings.sub-heading }}
    </h3>

    <h2 style="font-size: {{ section.settings.Heading_Font_Size }}px;">
      {{ section.settings.heading }}
    </h2>

    <p style="font-size: {{ section.settings.Paragraph_Font_Size }}px;">
      {{ section.settings.text }}
    </p>

    <div class="btn-wrapper" style="text-align: {{ section.settings.Button_Align }};">

      <a href="{{ section.settings.button_link }}" class="view_button">
        
          {{ section.settings.Button_text }}
      </a>

    </div>

</div>


</div>


{% schema %}
{
  "name": "Custom-Image-Text",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "mainImage",
      "label": "Select Main Image"
    },
    {
      "type": "text",
      "id": "sub-heading",
      "label": "Sub-Heading",
      "default": "Small"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Image with text"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "This is image on left and text on right section"
    },
    {
      "type": "select",
      "id": "main_image_width",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium",
      "label": "Image Width"
    },
    {
      "type": "range",
      "id": "Sub_Heading_Font_Size",
      "min": 10,
      "max": 25,
      "default": 15,
      "label": "Sub_Heading_Font_Size"
    },
    {
      "type": "range",
      "id": "Heading_Font_Size",
      "min": 35,
      "max": 70,
      "default": 40,
      "label": "Heading_Font_Size"
    },
    {
      "type": "range",
      "id": "Paragraph_Font_Size",
      "min": 15,
      "max": 40,
      "default": 18,
      "label": "Paragraph_Font_Size"
    },
    {
      "type": "select",
      "id": "Text_Align",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "label": "Text_Align"
    },
    {
      "type": "text",
      "id": "Button_text",
      "label": "Button_Text",
      "default": "Shop Now"
    },
    {
      "type": "select",
      "id": "Button_Align",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "label": "Button_Align"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "checkbox",
      "id": "image_right",
      "default": false,
      "label": "Enable Direction Changing"
    }
    
  ],

  "presets": [
    {
      "name": "Custom-Image-Text"
    }
  ]
}
{% endschema %}
