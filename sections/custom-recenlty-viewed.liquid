{{ 'custom-recently-viewed.css' | asset_url | stylesheet_tag }}

<section class="custom-recently-viewed-wrapper page-width">

  <div class="recently-viewed-header">

    <h2 class="recently-view-heading">{{ section.settings.heading }}</h2>

  </div>

  <div class="swiper recently-viewed-swiper">

    <div class="swiper-wrapper">


    </div>
  </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", function () {

      window.shopCurrency = "{{ shop.currency }}";

      {% comment %} formatting currency symbol  {% endcomment %}

      function formatPrice(cents) {
        return new Intl.NumberFormat(
          document.documentElement.lang || 'en-IN',
          {
            style: 'currency',
            currency: window.shopCurrency
          }
        ).format(cents / 100);
      }


      const wrapper = document.querySelector(".recently-viewed-swiper .swiper-wrapper");
      if (!wrapper) return;

      const key = "recently_viewed_products";
      const items = JSON.parse(localStorage.getItem(key)) || [];

      if (!items.length) {
        document.querySelector(".custom-recently-viewed-wrapper").style.display = "none";
        return;
      }

      items.forEach(item => {
        fetch(`/products/${item.handle}.js`)
          .then(res => res.json())
          .then(product => {

            const slide = document.createElement("div");
            slide.className = "swiper-slide";


            slide.innerHTML = `
              <a href="${product.url}">
                <img src="${product.images[0]}" alt="${product.title}">
                <h3>${product.title}</h3>
                <p>${formatPrice(product.price)}</p>
              </a>
            `;


            wrapper.appendChild(slide);
          });
      });

    });
</script>





{% schema %}
    {
    "name": "Custom Icon With Text",
    "class": "section",

    "settings": [
        {
            "type": "text",
            "id": "heading",
            "default": "Recently viewed",
            "label": "Heading"
        }
    ],

    "blocks": [
    ],

    "presets": [
        {
        "name": "Custom Recently viewed"
        }
    ]
    }
{% endschema %}
