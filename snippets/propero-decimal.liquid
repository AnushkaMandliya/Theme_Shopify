{% comment %} Product decimal main logic file of making the fractional quantity functionality getting data from metafileds and also adding the qunatity section for Site UI {% endcomment %}

{% comment %} adding this to Product template / grid for making decimal quantity functionality in UI {% endcomment %}

{% comment %} core logic for decimal quantity selector{% endcomment %}

{% comment %} default values for quantity {% endcomment %}

{% assign DEBUG = false %} 
{% assign decimal = false %} 
{% assign step = 1 %}
{% assign minimum_qty = 1 %}
{% assign product = product | default: card_product %}

{% comment %} raw product price that will chnage based on decimal logic {% endcomment %}

{% comment %} Display: disp {% endcomment %}
{% assign disp_price_min = product.price_min %}  {% comment %}Product normal minimum price {% endcomment %}

{% assign disp_price_compare = product.compare_at_price %} {% comment %}Product Compare at Price{% endcomment %}
{% assign disp_price = product.price %} {% comment %}Product Overall price{% endcomment %}

{% comment %}
  If custom decimal is part is selected assigning the values and making code functional for further process 
{% endcomment %}

{% if settings.pr_enable_decimal %}

	{% assign pri_unit = settings.pr_unit %}  {% comment %}primary unit of price such as meter, kg,  yards, etc...{% endcomment %}

    {% comment %}Sab decimal products ke rules same honge {% endcomment %}

  	{% if settings.pr_common_decimal %}

        {% comment %}
          If product has tag decimal than the custom decimal part is shown
        {% endcomment %}
		
		{% if product.tags contains 'decimal' %}

            {% comment %} Decimal activate + settings apply {% endcomment %}

			{% assign decimal = true %}  
		  	{% assign step = settings.pr_decimal_step_size %}
          	{% assign minimum_qty = settings.pr_minimum_qty %}

		{% endif%}
    
        {% comment %}
          If using metafields use this
        {% endcomment %}

  	{% elsif product.metafields.propero['decimal_step_size'] != blank %}  
		
		{% assign step = product.metafields.propero['decimal_step_size'] %}
		{% assign decimal = true %}

  	{% endif %}

    {% comment %} Checkout text preparation {% endcomment %}

	{% assign checkout_text = settings.pr_checkout_text |replace :"%UNIT%", pri_unit %}

	{% assign qty_multiple = 1 | divided_by : step %}

	{% assign checkout_text = checkout_text | replace :"%QUANTITY%", qty_multiple   %}	

{% endif %}

{% comment %} Har product ke alag rules ho non-common rules setting values based on per product decimal values assigned in product metafields {% endcomment %}

{% unless settings.pr_common_decimal %}

    {% if product.metafields.propero['minimum_qty'] != blank %}

        {% assign minimum_qty = product.metafields.propero['minimum_qty'] %}	

    {% endif %}

{% endunless %}

{% comment %} setting price based on decimal for product, collection, search {% endcomment %}

{% if template.name == 'product' or template.name == 'collection' or template.name == 'search' %}

    {% assign disp_price = product.price | divided_by : step %}
    {% assign disp_price_min = product.price_min | divided_by : step %}
    {% assign disp_price_compare = product.compare_at_price | divided_by : step %}

{% endif %}

{% comment %} this is for cart part {% endcomment %}

{% if item != blank %}

    {% if decimal %}

        {% comment %} converting the shopify cart quantity in decimal {% endcomment %}

        {% assign disp_quan = item.quantity | times : step %}
        {% assign disp_price_original = item.original_price | times : item.quantity  %}
        {% assign disp_price_final = item.final_price | divided_by : step %}

        {% comment %} cart script  {% endcomment %}

        <script>

            var step = 1;
            var min_qty =1;
            var commonSet = {{settings.pr_common_decimal}};
        
            if(commonSet){

                step = parseFloat({{ settings.pr_decimal_step_size }});
                min_qty= parseFloat({{ settings.pr_minimum_qty }});
            }

            {% comment %} metafields setting {% endcomment %}

            else{  

                step = parseFloat("{{ item.product.metafields.propero['decimal_step_size']}}");
                min_qty= parseFloat({{ item.product.metafields.propero['minimum_qty']}});
            }
        
        </script>

    {% comment %} Normal shopify quantity adding in integer format {% endcomment %}

    {% else %}

        {% assign disp_quan = item.quantity %}
        {% assign disp_price_original = item.original_price | times : item.quantity %} 
        {% assign disp_price_final = item.final_price %} 

    {% endif %}

{% endif %}